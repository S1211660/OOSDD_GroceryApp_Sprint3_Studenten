<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             x:Class="Grocery.App.Views.RegisterView"
             x:DataType="vm:RegisterViewModel"
             Title="Registreren">
    <StackLayout Padding="20" VerticalOptions="Center">
        <Label Text="Registreren" FontSize="24" HorizontalOptions="Center" Margin="0,0,0,20" />

        <Entry Placeholder="Naam" Text="{Binding Name}" />
        <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
        <Entry Placeholder="Wachtwoord" Text="{Binding Password}" IsPassword="True" />
        <Entry Placeholder="Bevestig wachtwoord" Text="{Binding ConfirmPassword}" IsPassword="True" />

        <Button Text="Registreer" Command="{Binding RegisterCommand}" Margin="0,20,0,10" />

        <Label Text="{Binding RegistrationMessage}" 
               TextColor="Red"
               HorizontalOptions="Center" />

        <Button Text="Ga naar inloggen" 
                Command="{Binding GoToLoginCommand}" 
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}" />
    </StackLayout>
</ContentPage>